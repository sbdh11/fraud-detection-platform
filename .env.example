# Copy to .env (or just rely on the defaults baked into docker-compose.yml).

# ---- host ports (chosen to avoid clashes with other local stacks) ----
DB_PORT=5544
MLFLOW_PORT=5500
BACKEND_PORT=8008
FRONTEND_PORT=3030

# ---- backend ----
# Inside compose the backend talks to "db" and "mlflow" by service name; these
# only matter if you run the backend outside docker.
DATABASE_URL=postgresql+asyncpg://fraud:fraud@db:5432/fraud
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=fraud-detection

SIM_ENABLED=true
SIM_INTERVAL_SECONDS=1.5
SIM_BURST=1
TRAIN_ON_STARTUP=true
TRAIN_ROWS=30000
DRIFT_INTERVAL_SECONDS=30
CORS_ORIGINS=*

# ---- frontend (inlined at build time) ----
# Point this at the URL the *browser* uses to reach the backend API.
NEXT_PUBLIC_API_BASE=http://localhost:8008/api
