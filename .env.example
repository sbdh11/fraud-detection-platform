# copy to .env to override the docker-compose defaults

# host ports
DB_PORT=5544
MLFLOW_PORT=5500
BACKEND_PORT=8008
FRONTEND_PORT=3030

# postgres (local dev creds; change for prod)
DB_USER=app
DB_PASSWORD=app
DB_NAME=frauddetect

# backend
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=fraud-detection
SIM_ENABLED=true
SIM_INTERVAL_SECONDS=1.5
SIM_BURST=1
TRAIN_ON_STARTUP=true
TRAIN_ROWS=30000
DRIFT_INTERVAL_SECONDS=30
CORS_ORIGINS=*
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME   # set only when running outside docker

# frontend (inlined at build)
NEXT_PUBLIC_API_BASE=http://localhost:8008/api
