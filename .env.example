# Copy to .env (or just rely on the defaults baked into docker-compose.yml).

# ---- host ports (chosen to avoid clashes with other local stacks) ----
DB_PORT=5544
MLFLOW_PORT=5500
BACKEND_PORT=8008
FRONTEND_PORT=3030

# ---- database (local-only dev credentials; change them for any real deployment) ----
DB_USER=app
DB_PASSWORD=app
DB_NAME=frauddetect

# ---- backend ----
# Inside compose the backend reaches "db" and "mlflow" by service name; DATABASE_URL
# is derived from DB_USER/DB_PASSWORD/DB_NAME there. Set it explicitly only when you
# run the backend outside docker (e.g. a managed Postgres):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=fraud-detection

SIM_ENABLED=true
SIM_INTERVAL_SECONDS=1.5
SIM_BURST=1
TRAIN_ON_STARTUP=true
TRAIN_ROWS=30000
DRIFT_INTERVAL_SECONDS=30
CORS_ORIGINS=*

# ---- frontend (inlined at build time) ----
# Point this at the URL the *browser* uses to reach the backend API.
NEXT_PUBLIC_API_BASE=http://localhost:8008/api
